# ============================================================
# REQUIRED
# ============================================================

# Google API Key for Gemini (get one at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Absolute path to the SQLite database file
DB_PATH=/absolute/path/to/ai-agents-clinic/database/clinic.db

# ============================================================
# AGENT URLS (defaults work for local development)
# ============================================================

# MCP Toolbox server URL (started by ./toolbox binary)
TOOLBOX_URL=http://127.0.0.1:5000

# Reservation agent A2A card URL (started by reservation_agent/__main__.py)
RESERVATION_AGENT_CARD_URL=http://localhost:8001/.well-known/agent.json

# Public URL of the reservation agent (used in agent card)
AGENT_URL=http://localhost:8001

# ============================================================
# TELEGRAM BOT (optional — only needed for Telegram integration)
# ============================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ADK server URL (where clinic_agent is running)
ADK_SERVER_URL=http://localhost:8000

# ADK app name (matches the agent folder name)
ADK_APP_NAME=clinic_agent

# ============================================================
# TELEGRAM WEBHOOK MODE (optional — for cloud deployments)
# Leave empty to use polling mode (default for local dev)
# ============================================================

# PORT=8080
# SERVICE_URL=https://your-cloud-run-service-url.run.app
